{
	"name": "dev-debug-panel",
	"version": "2.0.1",
	"description": "Draggable, resizable in-page debug panel. Per-id tabs, JSON state inspection, sink integration with dev-loggers.",
	"license": "ISC",
	"homepage": "https://github.com/rw3iss/dev-debug-panel#readme",
	"bugs": {
		"url": "https://github.com/rw3iss/dev-debug-panel/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rw3iss/dev-debug-panel.git"
	},
	"author": {
		"name": "Ryan Weiss",
		"email": "rw3iss@gmail.com",
		"url": "https://www.ryanweiss.net"
	},
	"type": "module",
	"main": "dist/index.cjs.js",
	"module": "dist/index.esm.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.esm.js",
			"require": "./dist/index.cjs.js"
		}
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"scripts": {
		"build": "node build.js && tsc --declaration --emitDeclarationOnly --outDir dist",
		"dev": "node build.js --watch",
		"clean": "rm -rf dist",
		"test": "node tests/clearTab.smoke.mjs",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"debug",
		"logging",
		"panel",
		"development",
		"typescript",
		"vanilla-js"
	],
	"peerDependencies": {
		"jsondiffpatch": "^0.7.3"
	},
	"dependencies": {
		"fast-safe-stringify": "^2.1.1",
		"jsondiffpatch": "^0.7.3"
	},
	"devDependencies": {
		"esbuild": "^0.21.5",
		"jsdom": "^29.1.1",
		"sass": "^1.93.2",
		"typescript": "^5.0.0"
	}
}
